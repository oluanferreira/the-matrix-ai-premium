{
  "name": "@the-matrix/visual",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite\" \"tsx watch src/server/index.ts\"",
    "dev:client": "vite",
    "dev:server": "tsx watch src/server/index.ts",
    "build": "tsc --noEmit && vite build",
    "start": "node --import tsx src/server/index.ts",
    "preview": "vite preview",
    "lint": "eslint src/ --cache --cache-location .eslintcache",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "express": "^4.22.1",
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.25",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
